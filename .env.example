# =============================
# Common / Development defaults
# =============================
# Boolean values: True/False (or 1/0, yes/no, on/off)
DEBUG=True
SECRET_KEY=change-me-dev-secret-key-min-50-characters
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=boat_rental
DB_USER=admin
DB_PASSWORD=admin

# For local compose (no redis password in dev)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# S3 / CDN
S3_BUCKET_NAME=yachts
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
S3_ENDPOINT_URL=https://yachts.hb.ru-msk.vkcloud-storage.ru
S3_REGION=ru-msk

# Security toggles (dev defaults)
# Boolean values: True/False (or 1/0, yes/no, on/off)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
USE_X_FORWARDED_HOST=True
CSRF_TRUSTED_ORIGINS=

# =============================
# Production/staging overrides
# =============================
# DEBUG=False
# ALLOWED_HOSTS=example.com,www.example.com
# REDIS_PASSWORD=strong-redis-password
# CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# USE_X_FORWARDED_HOST=True
# CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Nginx SSL template vars (prod)
# NGINX_SERVER_NAME=example.com www.example.com
# NGINX_SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
# NGINX_SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem
# NGINX_SSL_CHAIN_PATH=/etc/nginx/ssl/chain.pem

# Telegram notifications (assistant alerts on new bookings / status changes)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=-1002224453073

# Email (SMTP) — нотификации об обращениях через форму обратной связи
# Dev: оставьте пустым или используйте console backend (письма в stdout)
# Prod: укажите реальный SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.yandex.ru
# EMAIL_PORT=465
# EMAIL_USE_SSL=True
# EMAIL_USE_TLS=False
# EMAIL_HOST_USER=noreply@ahoyrent.ru
# EMAIL_HOST_PASSWORD=your-smtp-password
# DEFAULT_FROM_EMAIL=Ахой!Rent <noreply@ahoyrent.ru>
# FEEDBACK_EMAIL=info@ahoyrent.ru
